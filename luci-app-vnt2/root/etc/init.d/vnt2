#!/bin/sh /etc/rc.common
START=95
STOP=05

USE_PROCD=1

start_service() {
    config_load vnt2
    config_get enabled global enabled
    [ "$enabled" != "1" ] && return 0

    # 读取配置参数
    config_get token global token
    config_get device_id global device_id
    config_get device_name global device_name
    config_get server global server
    config_get stun_server global stun_server
    config_get password global password
    config_get server_encrypt global server_encrypt
    config_get mtu global mtu
    config_get virtual_ip global virtual_ip
    config_get port_mapping global port_mapping

    # 构造VNT-CLI命令
    cmd="/usr/sbin/vnt-cli -k $token -d $device_id -n $device_name -s $server -e $stun_server"
    [ -n "$password" ] && cmd="$cmd -w $password"
    [ "$server_encrypt" = "1" ] && cmd="$cmd -W"
    [ -n "$mtu" ] && cmd="$cmd -u $mtu"
    [ -n "$virtual_ip" ] && cmd="$cmd --ip $virtual_ip"
    [ -n "$port_mapping" ] && cmd="$cmd --mapping $port_mapping"

    # 后台启动VNT-CLI
    procd_open_instance
    procd_set_param command $cmd
    procd_set_param respawn  # 崩溃自动重启
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    # 停止VNT-CLI进程
    killall -9 vnt-cli >/dev/null 2>&1
}
