#!/bin/sh /etc/rc.common
START=90
STOP=10

config_load vnt2

get_vnt2_config() {
    config_get_bool enabled "$1" enabled 0
    config_get server "$1" server ""
    config_get port "$1" port "10086"
    config_get token "$1" token ""
    config_get interface "$1" interface "lan"
    config_get encrypt "$1" encrypt "aes-128"
    config_get mtu "$1" mtu "1400"
}

start() {
    config_foreach start_vnt2_instance vnt2
}

start_vnt2_instance() {
    local cfg="$1"
    get_vnt2_config "$cfg"
    
    if [ "$enabled" -ne 1 ]; then
        return 0
    fi
    
    /usr/bin/vnt2 client \
        --server "$server:$port" \
        --token "$token" \
        --interface "$interface" \
        --encrypt "$encrypt" \
        --mtu "$mtu" \
        --daemon > /var/log/vnt2.log 2>&1
    
    if [ $? -eq 0 ]; then
        echo "VNT2 instance $cfg started successfully"
    else
        echo "Failed to start VNT2 instance $cfg"
        return 1
    fi
}

stop() {
    killall -9 vnt2 > /dev/null 2>&1
    rm -f /var/run/vnt2.pid
}

restart() {
    stop
    sleep 1
    start
}
