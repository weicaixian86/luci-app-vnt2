#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

CONF="vnt2"
CLI_LOG="/tmp/vnt2-cli.log"
WEB_LOG="/tmp/vnt2-web.log"
DOWNLOAD_LOG="/tmp/vnt2-download.log"
CLI_TIME="/tmp/vnt2_cli_time"
WEB_TIME="/tmp/vnt2_web_time"
CLI_CONF_DIR="/etc/vnt2"
CLI_CONF_DEFAULT="${CLI_CONF_DIR}/vnt2-cli.toml"
CLI_CONF_FILE=""
RUNTIME_FILE="/tmp/.vnt2_runtime"
DOWNLOAD_CACHE_BASE="/tmp/vnt2-download-cache"
DOWNLOAD_CLI_STATE="/tmp/vnt2-download-cli.state"
DOWNLOAD_WEB_STATE="/tmp/vnt2-download-web.state"

. /lib/functions.sh
. /lib/functions/procd.sh

log_cli() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') vnt2-cli : $*" >>"${CLI_LOG}"
}

log_web() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') vnt2-web : $*" >>"${WEB_LOG}"
}

log_download() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') download : $*" >>"${DOWNLOAD_LOG}"
}

ensure_log_files() {
	[ -f "${CLI_LOG}" ] || : >"${CLI_LOG}"
	[ -f "${WEB_LOG}" ] || : >"${WEB_LOG}"
	[ -f "${DOWNLOAD_LOG}" ] || : >"${DOWNLOAD_LOG}"
}

trim_list() {
	local list="$1"
	echo "$list" | tr '\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g; s/^ //; s/ $//'
}

toml_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

sanitize_name() {
	printf '%s' "$1" | sed 's/[^A-Za-z0-9._-]/_/g'
}

append_toml_array() {
	local key="$1"
	shift
	local first=1
	[ "$#" -gt 0 ] || return 0

	printf '%s = [' "$key" >>"${CLI_CONF_FILE}"
	while [ "$#" -gt 0 ]; do
		local item="$1"
		shift
		[ -n "$item" ] || continue
		[ "$first" = "1" ] || printf ', ' >>"${CLI_CONF_FILE}"
		first=0
		printf '"%s"' "$(toml_escape "$item")" >>"${CLI_CONF_FILE}"
	done
	printf ']\n' >>"${CLI_CONF_FILE}"
}

append_toml_bool() {
	local key="$1"
	local val="$2"
	[ "$val" = "1" ] && echo "${key} = true" >>"${CLI_CONF_FILE}"
}

append_toml_string() {
	local key="$1"
	local val="$2"
	[ -n "$val" ] && printf '%s = "%s"\n' "$key" "$(toml_escape "$val")" >>"${CLI_CONF_FILE}"
}

append_toml_int() {
	local key="$1"
	local val="$2"
	[ -n "$val" ] && echo "${key} = ${val}" >>"${CLI_CONF_FILE}"
}

append_runtime_item() {
	local key="$1"
	local val="$2"
	[ -n "$val" ] && echo "${key}=${val}" >>"${RUNTIME_FILE}"
}

write_download_state() {
	local state_file="$1"
	local state="$2"
	local message="$3"
	local asset="$4"
	local tag="$5"
	local arch="$6"
	local path="$7"

	cat >"${state_file}" <<EOF
state=${state}
message=${message}
asset=${asset}
tag=${tag}
arch=${arch}
path=${path}
time=$(date '+%Y-%m-%d %H:%M:%S')
EOF
}

ensure_exec() {
	local bin="$1"
	[ -n "$bin" ] || return 1
	[ -f "$bin" ] || return 1
	chmod 755 "$bin" >/dev/null 2>&1
	return 0
}

find_uploaded_bin() {
	local name="$1"
	for file in "/tmp/${name}" "/tmp/${name//_/-}" "/tmp/${name}.bin"; do
		[ -f "$file" ] && {
			echo "$file"
			return 0
		}
	done
	return 1
}

detect_arch_name() {
	local mach arch
	mach="$(uname -m 2>/dev/null)"
	arch="$(opkg print-architecture 2>/dev/null | awk 'NR==1 {print $2}')"

	case "$mach" in
		x86_64|amd64)
			echo "x86_64"
			return 0
		;;
		aarch64|arm64)
			echo "aarch64"
			return 0
		;;
		armv7*|armv6*|arm*)
			echo "arm"
			return 0
		;;
		mips64el*)
			echo "mips64el"
			return 0
		;;
		mipsel*)
			echo "mipsel"
			return 0
		;;
		mips*)
			echo "mips"
			return 0
		;;
		i386|i486|i586|i686)
			echo "x86"
			return 0
		;;
	esac

	case "$arch" in
		*x86_64*|*amd64*)
			echo "x86_64"
		;;
		*aarch64*|*arm64*)
			echo "aarch64"
		;;
		*arm*)
			echo "arm"
		;;
		*mips64el*)
			echo "mips64el"
		;;
		*mipsel*)
			echo "mipsel"
		;;
		*mips*)
			echo "mips"
		;;
		*x86*|*i386*|*i686*)
			echo "x86"
		;;
		*)
			echo "${mach:-unknown}"
		;;
	esac
}

detect_arch_patterns() {
	case "$1" in
		x86_64)
			echo "x86_64 amd64 x86-64"
		;;
		aarch64)
			echo "aarch64 arm64 armv8"
		;;
		arm)
			echo "armv7 armhf armv6 arm"
		;;
		mips64el)
			echo "mips64el mips64"
		;;
		mipsel)
			echo "mipsel mipsel_24kc mipsel24kc"
		;;
		mips)
			echo "mips mips_24kc mips24kc"
		;;
		x86)
			echo "x86 i386 i686"
		;;
		*)
			echo "$1"
		;;
	esac
}

get_downloader() {
	if command -v uclient-fetch >/dev/null 2>&1; then
		echo "uclient-fetch"
		return 0
	fi
	if command -v curl >/dev/null 2>&1; then
		echo "curl"
		return 0
	fi
	if command -v wget >/dev/null 2>&1; then
		echo "wget"
		return 0
	fi
	return 1
}

download_file() {
	local url="$1"
	local out="$2"
	local downloader

	downloader="$(get_downloader)" || return 1

	case "$downloader" in
		uclient-fetch)
			uclient-fetch -q -T 20 \
				--header "User-Agent: luci-app-vnt2" \
				--header "Accept: application/vnd.github+json, application/octet-stream, */*" \
				-O "$out" "$url" >/dev/null 2>&1
		;;
		curl)
			curl -fsSL --connect-timeout 20 --retry 2 \
				-A "luci-app-vnt2" \
				-H "Accept: application/vnd.github+json, application/octet-stream, */*" \
				-o "$out" "$url" >/dev/null 2>&1
		;;
		wget)
			wget -q --timeout=20 \
				--header="User-Agent: luci-app-vnt2" \
				--header="Accept: application/vnd.github+json, application/octet-stream, */*" \
				-O "$out" "$url" >/dev/null 2>&1
		;;
		*)
			return 1
		;;
	esac
}

get_release_api_url() {
	local repo="$1"
	local tag="$2"

	if [ -z "$repo" ]; then
		repo="vnt-dev/vnts"
	fi

	if [ -z "$tag" ] || [ "$tag" = "latest" ]; then
		echo "https://api.github.com/repos/${repo}/releases/latest"
	else
		echo "https://api.github.com/repos/${repo}/releases/tags/${tag}"
	fi
}

select_release_asset() {
	local json_file="$1"
	local arch_patterns="$2"
	local urls asset pattern

	urls="$(sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$json_file" 2>/dev/null | sed 's#\\/#/#g')"
	[ -n "$urls" ] || return 1

	for pattern in $arch_patterns; do
		asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -i "$pattern" | grep -i 'unknown-linux-musl' | grep -iE '\.(tar\.gz|tgz|tar\.xz)$' | head -n1)"
		[ -n "$asset" ] && {
			echo "$asset"
			return 0
		}
	done

	for pattern in $arch_patterns; do
		asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | grep -iE '\.(tar\.gz|tgz|tar\.xz)$' | head -n1)"
		[ -n "$asset" ] && {
			echo "$asset"
			return 0
		}
	done

	for pattern in $arch_patterns; do
		asset="$(printf '%s\n' "$urls" | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | grep -iE '\.(tar\.gz|tgz|tar\.xz)$' | head -n1)"
		[ -n "$asset" ] && {
			echo "$asset"
			return 0
		}
	done

	for pattern in $arch_patterns; do
		asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | grep -iE '\.zip$' | head -n1)"
		[ -n "$asset" ] && {
			echo "$asset"
			return 0
		}
	done

	asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -iE '\.(tar\.gz|tgz|tar\.xz)$' | head -n1)"
	[ -n "$asset" ] && {
		echo "$asset"
		return 0
	}

	asset="$(printf '%s\n' "$urls" | grep -iE '\.(tar\.gz|tgz|tar\.xz|zip)$' | head -n1)"
	[ -n "$asset" ] && {
		echo "$asset"
		return 0
	}

	return 1
}

extract_release_asset() {
	local asset_file="$1"
	local dest_dir="$2"
	local base

	rm -rf "$dest_dir"
	mkdir -p "$dest_dir"

	case "$asset_file" in
		*.tar.gz|*.tgz)
			tar -xzf "$asset_file" -C "$dest_dir" >/dev/null 2>&1
		;;
		*.tar.xz)
			tar -xJf "$asset_file" -C "$dest_dir" >/dev/null 2>&1
		;;
		*.zip)
			if command -v unzip >/dev/null 2>&1; then
				unzip -qo "$asset_file" -d "$dest_dir" >/dev/null 2>&1
			else
				return 1
			fi
		;;
		*)
			base="$(basename "$asset_file")"
			cp -f "$asset_file" "${dest_dir}/${base}" >/dev/null 2>&1
		;;
	esac
}

locate_extracted_bin() {
	local root="$1"
	local name="$2"

	find "$root" -type f \( -name "$name" -o -name "${name}.bin" -o -name "${name//_/-}" \) 2>/dev/null | head -n1
}

cache_bundle_ready() {
	local extracted_dir="$1"
	local scope="$2"

	case "$scope" in
		cli)
			ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnt2_cli")" && ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnt2_ctrl")"
		;;
		web)
			ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnt2_web")"
		;;
		*)
			return 1
		;;
	esac
}

apply_downloaded_bins_to_uci() {
	local cfg="$1"
	local extracted_dir="$2"

	local cli_bin ctrl_bin web_bin
	cli_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_cli")"
	ctrl_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_ctrl")"
	web_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_web")"

	if ensure_exec "$cli_bin"; then
		uci -q set ${CONF}.${cfg}.vnt2_cli_bin="$cli_bin"
	fi
	if ensure_exec "$ctrl_bin"; then
		uci -q set ${CONF}.${cfg}.vnt2_ctrl_bin="$ctrl_bin"
	fi
	if ensure_exec "$web_bin"; then
		uci -q set ${CONF}.${cfg}.vnt2_web_bin="$web_bin"
	fi
	uci commit ${CONF} >/dev/null 2>&1
}

auto_download_bundle() {
	local cfg="$1"
	local scope="$2"
	local state_file="$3"
	local log_func="$4"

	local auto_download download_tag download_repo api_url arch_name arch_patterns
	local cache_key cache_dir json_file release_tag asset_url asset_name asset_file extracted_dir
	local cli_bin ctrl_bin web_bin

	config_get_bool auto_download "$cfg" "auto_download" "1"
	[ "$auto_download" = "1" ] || {
		write_download_state "$state_file" "disabled" "已关闭自动下载" "" "" "" ""
		return 1
	}

	config_get download_tag "$cfg" "download_tag" "latest"
	config_get download_repo "$cfg" "download_repo" "vnt-dev/vnts"
	[ -n "$download_tag" ] || download_tag="latest"
	[ -n "$download_repo" ] || download_repo="vnt-dev/vnts"

	arch_name="$(detect_arch_name)"
	arch_patterns="$(detect_arch_patterns "$arch_name")"
	cache_key="$(sanitize_name "${download_repo}_${download_tag}_${arch_name}")"
	cache_dir="${DOWNLOAD_CACHE_BASE}/${cache_key}"
	json_file="${cache_dir}/release.json"
	extracted_dir="${cache_dir}/extracted"

	mkdir -p "$cache_dir"

	if cache_bundle_ready "$extracted_dir" "$scope"; then
		log_download "检测到 ${scope} 已有缓存包，直接复用 ${extracted_dir}"
		write_download_state "$state_file" "cached" "已复用本地缓存程序" "$(basename "$cache_dir")" "$download_tag" "$arch_name" "$extracted_dir"
		apply_downloaded_bins_to_uci "$cfg" "$extracted_dir"
		return 0
	fi

	api_url="$(get_release_api_url "$download_repo" "$download_tag")"
	write_download_state "$state_file" "querying" "正在查询 GitHub Releases" "" "$download_tag" "$arch_name" ""
	log_download "开始查询 ${scope} 对应发行版：repo=${download_repo} tag=${download_tag} arch=${arch_name}"

	if ! download_file "$api_url" "$json_file"; then
		log_download "查询 GitHub Releases 失败：${api_url}"
		write_download_state "$state_file" "failed" "查询 GitHub Releases 失败" "" "$download_tag" "$arch_name" ""
		return 1
	fi

	release_tag="$(sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$json_file" | head -n1)"
	[ -n "$release_tag" ] || release_tag="$download_tag"
	asset_url="$(select_release_asset "$json_file" "$arch_patterns")" || {
		log_download "未找到匹配 ${arch_name} 的发行资源"
		write_download_state "$state_file" "failed" "未找到匹配当前架构的发行资源" "" "$release_tag" "$arch_name" ""
		return 1
	}

	asset_name="$(basename "$asset_url")"
	asset_file="${cache_dir}/${asset_name}"
	write_download_state "$state_file" "downloading" "正在下载发行资源" "$asset_name" "$release_tag" "$arch_name" ""
	log_download "选中资源 ${asset_name}"

	if [ ! -s "$asset_file" ]; then
		if ! download_file "$asset_url" "$asset_file"; then
			log_download "下载发行资源失败：${asset_url}"
			write_download_state "$state_file" "failed" "下载发行资源失败" "$asset_name" "$release_tag" "$arch_name" ""
			return 1
		fi
	else
		log_download "复用已下载资源 ${asset_file}"
	fi

	write_download_state "$state_file" "extracting" "正在解压或整理程序文件" "$asset_name" "$release_tag" "$arch_name" ""
	if ! extract_release_asset "$asset_file" "$extracted_dir"; then
		log_download "解压失败：${asset_file}"
		write_download_state "$state_file" "failed" "解压发行资源失败" "$asset_name" "$release_tag" "$arch_name" ""
		return 1
	fi

	cli_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_cli")"
	ctrl_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_ctrl")"
	web_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_web")"

	case "$scope" in
		cli)
			if ! ensure_exec "$cli_bin" || ! ensure_exec "$ctrl_bin"; then
				log_download "下载包中未找到完整的 vnt2_cli / vnt2_ctrl"
				write_download_state "$state_file" "failed" "下载包中未找到完整的 vnt2_cli / vnt2_ctrl" "$asset_name" "$release_tag" "$arch_name" ""
				return 1
			fi
			uci -q set ${CONF}.${cfg}.vnt2_cli_bin="$cli_bin"
			uci -q set ${CONF}.${cfg}.vnt2_ctrl_bin="$ctrl_bin"
			uci commit ${CONF} >/dev/null 2>&1
			log_download "CLI 程序已准备完成：cli=${cli_bin} ctrl=${ctrl_bin}"
			write_download_state "$state_file" "success" "已自动下载并准备 vnt2_cli / vnt2_ctrl" "$asset_name" "$release_tag" "$arch_name" "$cli_bin"
			return 0
		;;
		web)
			if ! ensure_exec "$web_bin"; then
				log_download "下载包中未找到 vnt2_web"
				write_download_state "$state_file" "failed" "下载包中未找到 vnt2_web" "$asset_name" "$release_tag" "$arch_name" ""
				return 1
			fi
			uci -q set ${CONF}.${cfg}.vnt2_web_bin="$web_bin"
			uci commit ${CONF} >/dev/null 2>&1
			log_download "Web 程序已准备完成：web=${web_bin}"
			write_download_state "$state_file" "success" "已自动下载并准备 vnt2_web" "$asset_name" "$release_tag" "$arch_name" "$web_bin"
			return 0
		;;
	esac

	write_download_state "$state_file" "failed" "未知下载范围" "$asset_name" "$release_tag" "$arch_name" ""
	return 1
}

prepare_binary() {
	local cfg="$1"
	local option="$2"
	local default_path="$3"
	local upload_name="$4"
	local log_func="$5"
	local state_file="$6"
	local scope="$7"

	local bin
	config_get bin "$cfg" "$option" "$default_path"

	if ensure_exec "$bin"; then
		echo "$bin"
		return 0
	fi

	if auto_download_bundle "$cfg" "$scope" "$state_file" "$log_func"; then
		bin="$(uci -q get ${CONF}.${cfg}.${option})"
		if ensure_exec "$bin"; then
			echo "$bin"
			return 0
		fi
	fi

	local uploaded
	uploaded="$(find_uploaded_bin "$upload_name")"
	if [ -n "$uploaded" ]; then
		$log_func "自动下载不可用，检测到上传程序 ${uploaded}，将回退使用该路径启动"
		log_download "${scope} 自动下载失败，回退到本地上传程序 ${uploaded}"
		bin="$uploaded"
		uci -q set ${CONF}.${cfg}.${option}="$bin"
		uci commit ${CONF}
		write_download_state "$state_file" "fallback" "自动下载失败，已回退到本地上传程序" "$(basename "$uploaded")" "" "$(detect_arch_name)" "$uploaded"
	fi

	ensure_exec "$bin" || return 1
	echo "$bin"
	return 0
}

configure_network() {
	local tun_name="$1"
	local forward_list="$2"

	[ -n "$tun_name" ] || tun_name="vnt-tun"

	uci -q delete network.VNT2
	uci set network.VNT2='interface'
	uci set network.VNT2.proto='none'
	uci set network.VNT2.device="$tun_name"
	uci set network.VNT2.ifname="$tun_name"

	uci -q delete firewall.vnt2zone
	uci set firewall.vnt2zone='zone'
	uci set firewall.vnt2zone.name='VNT2'
	uci set firewall.vnt2zone.input='ACCEPT'
	uci set firewall.vnt2zone.output='ACCEPT'
	uci set firewall.vnt2zone.forward='ACCEPT'
	uci set firewall.vnt2zone.masq='1'
	uci set firewall.vnt2zone.mtu_fix='1'
	uci set firewall.vnt2zone.network='VNT2'

	case " $forward_list " in
		*" vnt2fwlan "*)
			uci set firewall.vnt2fwlan='forwarding'
			uci set firewall.vnt2fwlan.src='VNT2'
			uci set firewall.vnt2fwlan.dest='lan'
		;;
		*)
			uci -q delete firewall.vnt2fwlan
		;;
	esac

	case " $forward_list " in
		*" vnt2fwwan "*)
			uci set firewall.vnt2fwwan='forwarding'
			uci set firewall.vnt2fwwan.src='VNT2'
			uci set firewall.vnt2fwwan.dest='wan'
		;;
		*)
			uci -q delete firewall.vnt2fwwan
		;;
	esac

	case " $forward_list " in
		*" lanfwvnt2 "*)
			uci set firewall.lanfwvnt2='forwarding'
			uci set firewall.lanfwvnt2.src='lan'
			uci set firewall.lanfwvnt2.dest='VNT2'
		;;
		*)
			uci -q delete firewall.lanfwvnt2
		;;
	esac

	case " $forward_list " in
		*" wanfwvnt2 "*)
			uci set firewall.wanfwvnt2='forwarding'
			uci set firewall.wanfwvnt2.src='wan'
			uci set firewall.wanfwvnt2.dest='VNT2'
		;;
		*)
			uci -q delete firewall.wanfwvnt2
		;;
	esac

	[ -n "$(uci changes network)" ] && uci commit network && /etc/init.d/network reload >/dev/null 2>&1
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
	sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1
}

cleanup_network() {
	uci -q delete network.VNT2
	uci -q delete firewall.vnt2zone
	uci -q delete firewall.vnt2fwlan
	uci -q delete firewall.vnt2fwwan
	uci -q delete firewall.lanfwvnt2
	uci -q delete firewall.wanfwvnt2
	[ -n "$(uci changes network)" ] && uci commit network && /etc/init.d/network reload >/dev/null 2>&1
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

configure_web_firewall() {
	local host="$1"
	local port="$2"
	local wan="$3"

	uci -q delete firewall.vnt2web
	if [ "$wan" = "1" ] && [ -n "$port" ] && [ "$host" = "0.0.0.0" -o "$host" = "::" ]; then
		uci set firewall.vnt2web='rule'
		uci set firewall.vnt2web.name='vnt2_web'
		uci set firewall.vnt2web.src='wan'
		uci set firewall.vnt2web.target='ACCEPT'
		uci set firewall.vnt2web.proto='tcp'
		uci set firewall.vnt2web.dest_port="$port"
	fi
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

cleanup_web_firewall() {
	uci -q delete firewall.vnt2web
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

collect_list_values() {
	local cfg="$1"
	local opt="$2"
	> "${RUNTIME_FILE}.${opt}"
	config_list_foreach "$cfg" "$opt" append_runtime_item "$opt"
	sed -n "s/^${opt}=//p" "${RUNTIME_FILE}" 2>/dev/null >"${RUNTIME_FILE}.${opt}"
}

build_cli_config() {
	local cfg="$1"
	local network_code ip device_id device_name mtu tun_name
	local no_punch rtx compress fec no_nat no_tun allow_mapping
	local cert_mode ctrl_port tunnel_port password vnt2_forward
	local bind_dev cli_conf_file cli_conf_dir

	local server_list input_list output_list mapping_list udp_stun_list tcp_stun_list
	local server_args="" input_args="" output_args="" mapping_args="" udp_stun_args="" tcp_stun_args=""

	rm -f "${RUNTIME_FILE}" "${RUNTIME_FILE}".*

	config_get network_code "$cfg" "network_code"
	[ -n "$network_code" ] || {
		log_cli "网络编号不能为空"
		return 1
	}

	config_list_foreach "$cfg" server append_runtime_item server
	config_list_foreach "$cfg" input append_runtime_item input
	config_list_foreach "$cfg" output append_runtime_item output
	config_list_foreach "$cfg" port_mapping append_runtime_item port_mapping
	config_list_foreach "$cfg" udp_stun append_runtime_item udp_stun
	config_list_foreach "$cfg" tcp_stun append_runtime_item tcp_stun

	server_list="$(sed -n 's/^server=//p' "${RUNTIME_FILE}" 2>/dev/null)"
	input_list="$(sed -n 's/^input=//p' "${RUNTIME_FILE}" 2>/dev/null)"
	output_list="$(sed -n 's/^output=//p' "${RUNTIME_FILE}" 2>/dev/null)"
	mapping_list="$(sed -n 's/^port_mapping=//p' "${RUNTIME_FILE}" 2>/dev/null)"
	udp_stun_list="$(sed -n 's/^udp_stun=//p' "${RUNTIME_FILE}" 2>/dev/null)"
	tcp_stun_list="$(sed -n 's/^tcp_stun=//p' "${RUNTIME_FILE}" 2>/dev/null)"

	server_list="$(trim_list "$server_list")"
	[ -n "$server_list" ] || {
		log_cli "服务器地址不能为空"
		rm -f "${RUNTIME_FILE}" "${RUNTIME_FILE}".*
		return 1
	}

	config_get ip "$cfg" "ip"
	config_get device_id "$cfg" "device_id"
	config_get device_name "$cfg" "device_name"
	config_get mtu "$cfg" "mtu"
	config_get tun_name "$cfg" "tun_name"
	config_get_bool no_punch "$cfg" "no_punch" "0"
	config_get_bool rtx "$cfg" "rtx" "0"
	config_get_bool compress "$cfg" "compress" "0"
	config_get_bool fec "$cfg" "fec" "0"
	config_get_bool no_nat "$cfg" "no_nat" "0"
	config_get_bool no_tun "$cfg" "no_tun" "0"
	config_get_bool allow_mapping "$cfg" "allow_mapping" "0"
	config_get cert_mode "$cfg" "cert_mode"
	config_get ctrl_port "$cfg" "ctrl_port"
	config_get tunnel_port "$cfg" "tunnel_port"
	config_get password "$cfg" "password"
	config_get vnt2_forward "$cfg" "vnt2_forward"
	config_get bind_dev "$cfg" "bind_dev"
	config_get cli_conf_file "$cfg" "cli_conf_file" "${CLI_CONF_DEFAULT}"

	[ -n "$cli_conf_file" ] || cli_conf_file="${CLI_CONF_DEFAULT}"
	CLI_CONF_FILE="$cli_conf_file"
	cli_conf_dir="$(dirname "${CLI_CONF_FILE}")"
	[ -n "$cli_conf_dir" ] || cli_conf_dir="${CLI_CONF_DIR}"

	mkdir -p "${cli_conf_dir}"
	: >"${CLI_CONF_FILE}"
	printf 'network_code = "%s"\n' "$(toml_escape "$network_code")" >>"${CLI_CONF_FILE}"

	for item in $server_list; do
		server_args="${server_args}__ITEM__${item}"
	done
	for item in $(trim_list "$input_list"); do
		input_args="${input_args}__ITEM__${item}"
	done
	for item in $(trim_list "$output_list"); do
		output_args="${output_args}__ITEM__${item}"
	done
	for item in $(trim_list "$mapping_list"); do
		mapping_args="${mapping_args}__ITEM__${item}"
	done
	for item in $(trim_list "$udp_stun_list"); do
		udp_stun_args="${udp_stun_args}__ITEM__${item}"
	done
	for item in $(trim_list "$tcp_stun_list"); do
		tcp_stun_args="${tcp_stun_args}__ITEM__${item}"
	done

	[ -n "$server_args" ] && append_toml_array "server" $(printf '%s\n' "$server_args" | sed 's/__ITEM__/\n/g' | sed '/^$/d')
	[ -n "$ip" ] && append_toml_string "ip" "$ip"
	[ -n "$device_id" ] && append_toml_string "device_id" "$device_id"
	[ -n "$device_name" ] && append_toml_string "device_name" "$device_name"
	[ -n "$tun_name" ] && append_toml_string "tun_name" "$tun_name"
	[ -n "$password" ] && append_toml_string "password" "$password"
	[ -n "$cert_mode" ] && append_toml_string "cert_mode" "$cert_mode"
	[ -n "$mtu" ] && append_toml_int "mtu" "$mtu"
	[ -n "$ctrl_port" ] && append_toml_int "ctrl_port" "$ctrl_port"
	[ -n "$tunnel_port" ] && append_toml_int "tunnel_port" "$tunnel_port"
	append_toml_bool "no_punch" "$no_punch"
	append_toml_bool "rtx" "$rtx"
	append_toml_bool "compress" "$compress"
	append_toml_bool "fec" "$fec"
	append_toml_bool "no_nat" "$no_nat"
	append_toml_bool "no_tun" "$no_tun"
	append_toml_bool "allow_mapping" "$allow_mapping"
	[ -n "$input_args" ] && append_toml_array "input" $(printf '%s\n' "$input_args" | sed 's/__ITEM__/\n/g' | sed '/^$/d')
	[ -n "$output_args" ] && append_toml_array "output" $(printf '%s\n' "$output_args" | sed 's/__ITEM__/\n/g' | sed '/^$/d')
	[ -n "$mapping_args" ] && append_toml_array "port_mapping" $(printf '%s\n' "$mapping_args" | sed 's/__ITEM__/\n/g' | sed '/^$/d')
	[ -n "$udp_stun_args" ] && append_toml_array "udp_stun" $(printf '%s\n' "$udp_stun_args" | sed 's/__ITEM__/\n/g' | sed '/^$/d')
	[ -n "$tcp_stun_args" ] && append_toml_array "tcp_stun" $(printf '%s\n' "$tcp_stun_args" | sed 's/__ITEM__/\n/g' | sed '/^$/d')

	echo "$vnt2_forward" > /tmp/vnt2_forward.list
	echo "$bind_dev" > /tmp/vnt2_bind_dev
	rm -f "${RUNTIME_FILE}" "${RUNTIME_FILE}".*
	return 0
}

start_cli_instance() {
	local cfg="$1"
	local enabled cli_bin ctrl_bin tun_name no_tun forward_list bind_dev cli_conf_file

	config_get_bool enabled "$cfg" "enabled" "0"
	if [ "$enabled" != "1" ]; then
		log_cli "未启用，跳过启动"
		return 0
	fi

	log_cli "开始启动"
	config_get cli_bin "$cfg" "vnt2_cli_bin" "/usr/bin/vnt2_cli"
	config_get ctrl_bin "$cfg" "vnt2_ctrl_bin" "/usr/bin/vnt2_ctrl"

	if ! ensure_exec "$cli_bin" || ! ensure_exec "$ctrl_bin"; then
		log_cli "检测到 CLI/CTRL 程序不完整，尝试自动下载或回退到上传程序"
		cli_bin="$(prepare_binary "$cfg" "vnt2_cli_bin" "/usr/bin/vnt2_cli" "vnt2_cli" log_cli "$DOWNLOAD_CLI_STATE" "cli")" || {
			log_cli "启动失败：未找到完整的 vnt2_cli / vnt2_ctrl，请上传或安装程序"
			return 1
		}
		ctrl_bin="$(uci -q get ${CONF}.${cfg}.vnt2_ctrl_bin)"
		if ! ensure_exec "$ctrl_bin"; then
			log_cli "启动失败：vnt2_ctrl 缺失，自动下载或上传回退未准备完整"
			return 1
		fi
	else
		log_cli "检测到现有 CLI/CTRL 程序完整：cli=${cli_bin} ctrl=${ctrl_bin}"
	fi

	config_get cli_conf_file "$cfg" "cli_conf_file" "${CLI_CONF_DEFAULT}"
	[ -n "$cli_conf_file" ] || cli_conf_file="${CLI_CONF_DEFAULT}"
	CLI_CONF_FILE="$cli_conf_file"

	if ! build_cli_config "$cfg"; then
		log_cli "启动失败：生成配置文件失败"
		return 1
	fi

	config_get tun_name "$cfg" "tun_name" "vnt-tun"
	config_get_bool no_tun "$cfg" "no_tun" "0"
	forward_list="$(cat /tmp/vnt2_forward.list 2>/dev/null)"
	bind_dev="$(cat /tmp/vnt2_bind_dev 2>/dev/null)"
	rm -f /tmp/vnt2_forward.list /tmp/vnt2_bind_dev

	if [ "$no_tun" != "1" ]; then
		configure_network "$tun_name" "$forward_list"
	else
		cleanup_network
	fi

	log_cli "使用 ${cli_bin} 启动，配置文件 ${CLI_CONF_FILE}"
	procd_open_instance "vnt2_cli"
	[ -n "$bind_dev" ] && procd_set_param env VNT_BIND_DEV="$bind_dev"
	procd_set_param command /bin/sh -c "exec \"${cli_bin}\" --conf \"${CLI_CONF_FILE}\" >>\"${CLI_LOG}\" 2>&1"
	procd_set_param stdout 0
	procd_set_param stderr 0
	procd_set_param respawn
	procd_set_param file "${CLI_CONF_FILE}"
	procd_set_param limits core="unlimited"
	procd_set_param limits nofile="1048576 1048576"
	procd_set_param term_timeout 10
	procd_close_instance
	date +%s >"${CLI_TIME}"
	log_cli "启动命令已提交"
}

start_web_instance() {
	local cfg="$1"
	local enabled web_bin web_host web_port web_wan log_level

	config_get_bool enabled "$cfg" "enabled" "0"
	if [ "$enabled" != "1" ]; then
		log_web "未启用，跳过启动"
		return 0
	fi

	log_web "开始启动"
	web_bin="$(prepare_binary "$cfg" "vnt2_web_bin" "/usr/bin/vnt2_web" "vnt2_web" log_web "$DOWNLOAD_WEB_STATE" "web")" || {
		log_web "启动失败：未找到可执行文件，请上传或安装 vnt2_web"
		return 1
	}

	config_get web_host "$cfg" "web_host" "127.0.0.1"
	config_get web_port "$cfg" "web_port" "19099"
	config_get_bool web_wan "$cfg" "web_wan" "0"
	config_get log_level "$cfg" "log_level" "info"

	configure_web_firewall "$web_host" "$web_port" "$web_wan"

	log_web "使用 ${web_bin} 监听 ${web_host}:${web_port}"
	procd_open_instance "vnt2_web"
	procd_set_param env RUST_LOG="$log_level"
	procd_set_param command /bin/sh -c "exec \"${web_bin}\" --addr \"${web_host}:${web_port}\" >>\"${WEB_LOG}\" 2>&1"
	procd_set_param stdout 0
	procd_set_param stderr 0
	procd_set_param respawn
	procd_set_param limits core="unlimited"
	procd_set_param limits nofile="1048576 1048576"
	procd_set_param term_timeout 10
	procd_close_instance
	date +%s >"${WEB_TIME}"
	log_web "启动命令已提交"
}

start_service() {
	ensure_log_files
	log_cli "服务启动流程开始"
	log_web "服务启动流程开始"
	log_download "服务启动流程开始"
	config_load "${CONF}"
	start_cli_instance "vnt2_cli"
	start_web_instance "vnt2_web"
	log_download "服务启动流程结束"
}

stop_service() {
	ensure_log_files
	log_cli "服务停止流程开始"
	log_web "服务停止流程开始"
	log_download "服务停止流程开始"
	rm -f "${CLI_TIME}" "${WEB_TIME}" "${RUNTIME_FILE}" "${RUNTIME_FILE}".* /tmp/vnt2_forward.list /tmp/vnt2_bind_dev
	cleanup_network
	cleanup_web_firewall
	log_cli "服务已停止"
	log_web "服务已停止"
	log_download "服务停止流程结束"
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "${CONF}"
}
