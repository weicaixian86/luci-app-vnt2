#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

# 加载UCI配置
load_config() {
    config_load vnt2

    # 客户端配置
    config_get_bool cli_enabled client enabled 0
    config_get cli_token client token ""
    config_get cli_device_id client device_id ""
    config_get cli_server client server ""
    config_get cli_interface client interface "vnt2"
    config_get cli_mtu client mtu "1400"
    config_get cli_log_level client log_level "info"
    config_get cli_log_path client log_path "/tmp/vnt2.log"
    config_get cli_custom_args client custom_args ""
    config_list_get client route cli_routes

    # 服务端配置
    config_get_bool srv_enabled server enabled 0
    config_get srv_port server port "29872"
    config_get srv_gateway server gateway "10.26.0.1"
    config_get srv_netmask server netmask "255.255.255.0"
    config_get_bool srv_web_management server web_management 0
    config_get srv_web_port server web_port "29873"
    config_get_bool srv_log_enabled server log_enabled 1
    config_get srv_log_level server log_level "info"
    config_get srv_log_path server log_path "/tmp/vnts2.log"
    config_get srv_bind_addr server bind_addr "0.0.0.0"
    config_get_bool srv_port_forward server port_forward 0
    config_get srv_port_forward_bind server port_forward_bind "0.0.0.0"
    config_get srv_custom_args server custom_args ""
    config_list_get server token_whitelist srv_tokens
}

# 生成客户端启动参数
build_client_args() {
    cli_args=""
    [ -n "$cli_token" ] && cli_args="$cli_args --token $cli_token"
    [ -n "$cli_device_id" ] && cli_args="$cli_args --device-id $cli_device_id"
    [ -n "$cli_server" ] && cli_args="$cli_args --server $cli_server"
    [ -n "$cli_interface" ] && cli_args="$cli_args --if-name $cli_interface"
    [ -n "$cli_mtu" ] && cli_args="$cli_args --mtu $cli_mtu"
    [ -n "$cli_log_level" ] && cli_args="$cli_args --log-level $cli_log_level"
    [ -n "$cli_log_path" ] && cli_args="$cli_args --log-file $cli_log_path"
    # 路由
    for route in $cli_routes; do
        cli_args="$cli_args --route $route"
    done
    # 自定义参数
    [ -n "$cli_custom_args" ] && cli_args="$cli_args $cli_custom_args"
}

# 生成服务端启动参数
build_server_args() {
    srv_args=""
    [ -n "$srv_port" ] && srv_args="$srv_args --port $srv_port"
    [ -n "$srv_bind_addr" ] && srv_args="$srv_args --bind $srv_bind_addr"
    [ -n "$srv_gateway" ] && srv_args="$srv_args --gateway $srv_gateway"
    [ -n "$srv_netmask" ] && srv_args="$srv_args --netmask $srv_netmask"
    [ "$srv_web_management" = "1" ] && srv_args="$srv_args --web --web-port $srv_web_port"
    [ "$srv_log_enabled" = "1" ] && [ -n "$srv_log_path" ] && srv_args="$srv_args --log-file $srv_log_path"
    [ -n "$srv_log_level" ] && srv_args="$srv_args --log-level $srv_log_level"
    [ "$srv_port_forward" = "1" ] && srv_args="$srv_args --port-forward --port-forward-bind $srv_port_forward_bind"
    # Token白名单
    for token in $srv_tokens; do
        srv_args="$srv_args --token-white-list $token"
    done
    # 自定义参数
    [ -n "$srv_custom_args" ] && srv_args="$srv_args $srv_custom_args"
}

# 启动服务
start_service() {
    load_config
    build_client_args
    build_server_args

    # 启动客户端
    if [ "$cli_enabled" = "1" ]; then
        procd_open_instance client
        procd_set_param command /usr/bin/vnt2-cli $cli_args
        procd_set_param respawn 3 5 10
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_close_instance
    fi

    # 启动服务端
    if [ "$srv_enabled" = "1" ]; then
        procd_open_instance server
        procd_set_param command /usr/bin/vnts2 $srv_args
        procd_set_param respawn 3 5 10
        procd_set_param stdout 1
        procd_set_param stderr 1
        procd_close_instance
    fi
}

# 停止服务
stop_service() {
    # 停止所有进程
    killall -9 vnt2-cli 2>/dev/null
    killall -9 vnts2 2>/dev/null
    sleep 0.5
}

# 重启服务
restart() {
    stop
    start
}
