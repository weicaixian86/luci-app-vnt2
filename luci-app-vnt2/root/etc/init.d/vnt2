#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

CONF="vnt2"

CLI_LOG="/tmp/vnt2-cli.log"
WEB_LOG="/tmp/vnt2-web.log"
SERVER_LOG="/tmp/vnts2.log"
DOWNLOAD_LOG="/tmp/vnt2-download.log"

CLI_TIME="/tmp/vnt2_cli_time"
WEB_TIME="/tmp/vnt2_web_time"
SERVER_TIME="/tmp/vnts2_time"

CLI_CONF_DEFAULT="/etc/config/vnt2.toml"
SERVER_CONF_DEFAULT="/etc/config/vnts2.toml"

CLI_CONF_FILE=""
SERVER_CONF_FILE=""

DOWNLOAD_CACHE_BASE="/tmp/vnt2-download-cache"
DOWNLOAD_CLI_STATE="/tmp/vnt2-download-cli.state"
DOWNLOAD_WEB_STATE="/tmp/vnt2-download-web.state"
DOWNLOAD_SERVER_STATE="/tmp/vnt2-download-server.state"

. /lib/functions.sh
. /lib/functions/procd.sh

log_cli() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') vnt2-cli : $*" >>"${CLI_LOG}"
}

log_web() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') vnt2-web : $*" >>"${WEB_LOG}"
}

log_server() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') vnts2 : $*" >>"${SERVER_LOG}"
}

log_download() {
	echo "$(date '+%Y-%m-%d %H:%M:%S') download : $*" >>"${DOWNLOAD_LOG}"
}

ensure_log_files() {
	[ -f "${CLI_LOG}" ] || : >"${CLI_LOG}"
	[ -f "${WEB_LOG}" ] || : >"${WEB_LOG}"
	[ -f "${SERVER_LOG}" ] || : >"${SERVER_LOG}"
	[ -f "${DOWNLOAD_LOG}" ] || : >"${DOWNLOAD_LOG}"
}

trim_value() {
	echo "$1" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

sanitize_name() {
	printf '%s' "$1" | sed 's/[^A-Za-z0-9._-]/_/g'
}

write_download_state() {
	local state_file="$1"
	local state="$2"
	local message="$3"
	local asset="$4"
	local tag="$5"
	local arch="$6"
	local path="$7"

	cat >"${state_file}" <<EOF
state=${state}
message=${message}
asset=${asset}
tag=${tag}
arch=${arch}
path=${path}
time=$(date '+%Y-%m-%d %H:%M:%S')
EOF
}

ensure_exec() {
	local bin="$1"
	[ -n "$bin" ] || return 1
	[ -f "$bin" ] || return 1
	chmod 755 "$bin" >/dev/null 2>&1
	return 0
}

find_uploaded_bin() {
	local name="$1"
	for file in "/tmp/${name}" "/tmp/${name//_/-}" "/tmp/${name}.bin"; do
		[ -f "$file" ] && {
			echo "$file"
			return 0
		}
	done
	return 1
}

detect_arch_name() {
	local mach arch
	mach="$(uname -m 2>/dev/null)"
	arch="$(opkg print-architecture 2>/dev/null | awk 'NR==1 {print $2}')"

	case "$mach" in
		x86_64|amd64)
			echo "x86_64"
			return 0
		;;
		aarch64|arm64)
			echo "aarch64"
			return 0
		;;
		armv7*|armv6*|arm*)
			echo "arm"
			return 0
		;;
		mips64el*)
			echo "mips64el"
			return 0
		;;
		mipsel*)
			echo "mipsel"
			return 0
		;;
		mips*)
			echo "mips"
			return 0
		;;
		i386|i486|i586|i686)
			echo "x86"
			return 0
		;;
	esac

	case "$arch" in
		*x86_64*|*amd64*)
			echo "x86_64"
		;;
		*aarch64*|*arm64*)
			echo "aarch64"
		;;
		*arm*)
			echo "arm"
		;;
		*mips64el*)
			echo "mips64el"
		;;
		*mipsel*)
			echo "mipsel"
		;;
		*mips*)
			echo "mips"
		;;
		*x86*|*i386*|*i686*)
			echo "x86"
		;;
		*)
			echo "${mach:-unknown}"
		;;
	esac
}

detect_arch_patterns() {
	case "$1" in
		x86_64)
			echo "x86_64 amd64 x86-64"
		;;
		aarch64)
			echo "aarch64 arm64 armv8"
		;;
		arm)
			echo "armv7 armhf armv6 arm"
		;;
		mips64el)
			echo "mips64el mips64"
		;;
		mipsel)
			echo "mipsel mipsel_24kc mipsel24kc"
		;;
		mips)
			echo "mips mips_24kc mips24kc"
		;;
		x86)
			echo "x86 i386 i686"
		;;
		*)
			echo "$1"
		;;
	esac
}

get_downloader() {
	if command -v uclient-fetch >/dev/null 2>&1; then
		echo "uclient-fetch"
		return 0
	fi
	if command -v curl >/dev/null 2>&1; then
		echo "curl"
		return 0
	fi
	if command -v wget >/dev/null 2>&1; then
		echo "wget"
		return 0
	fi
	return 1
}

download_file() {
	local url="$1"
	local out="$2"
	local downloader

	downloader="$(get_downloader)" || return 1

	case "$downloader" in
		uclient-fetch)
			uclient-fetch -q -T 20 \
				--header "User-Agent: luci-app-vnt2" \
				--header "Accept: application/vnd.github+json, application/octet-stream, */*" \
				-O "$out" "$url" >/dev/null 2>&1
		;;
		curl)
			curl -fsSL --connect-timeout 20 --retry 2 \
				-A "luci-app-vnt2" \
				-H "Accept: application/vnd.github+json, application/octet-stream, */*" \
				-o "$out" "$url" >/dev/null 2>&1
		;;
		wget)
			wget -q --timeout=20 \
				--header="User-Agent: luci-app-vnt2" \
				--header="Accept: application/vnd.github+json, application/octet-stream, */*" \
				-O "$out" "$url" >/dev/null 2>&1
		;;
		*)
			return 1
		;;
	esac
}

get_release_api_url() {
	local repo="$1"
	local tag="$2"

	[ -n "$repo" ] || repo="vnt-dev/vnt"

	if [ -z "$tag" ] || [ "$tag" = "latest" ]; then
		echo "https://api.github.com/repos/${repo}/releases/latest"
	else
		echo "https://api.github.com/repos/${repo}/releases/tags/${tag}"
	fi
}

select_release_asset() {
	local json_file="$1"
	local arch_patterns="$2"
	local scope="$3"
	local urls asset pattern

	urls="$(sed -n 's/.*"browser_download_url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$json_file" 2>/dev/null | sed 's#\\/#/#g')"
	[ -n "$urls" ] || return 1

	case "$scope" in
		cli|web)
			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -i "$pattern" | grep -i 'unknown-linux-musl' | grep -iE '(\.tar\.gz|\.tgz|\.tar\.xz|\.zip)$' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | grep -iE '(\.tar\.gz|\.tgz|\.tar\.xz|\.zip)$' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | grep -iE '(\.tar\.gz|\.tgz|\.tar\.xz|\.zip)$' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -i "$pattern" | grep -iE '(vnt|cli|ctrl|web)' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			asset="$(printf '%s\n' "$urls" | grep -iE '/vnt(2)?[-_]' | head -n1)"
			[ -n "$asset" ] && {
				echo "$asset"
				return 0
			}
		;;
		server)
			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -iE '/vnts(2)?[-_]' | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | grep -iE '(\.tar\.gz|\.tgz|\.tar\.xz|\.zip)$' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -iE '/vnts(2)?[-_]' | grep -i "$pattern" | grep -iE '(linux|musl|openwrt)' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -i "$pattern" | grep -iE '(vnts|server)' | grep -iE '(linux|musl|openwrt)' | grep -iE '(\.tar\.gz|\.tgz|\.tar\.xz|\.zip)$' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			for pattern in $arch_patterns; do
				asset="$(printf '%s\n' "$urls" | grep -i "$pattern" | grep -iE '(vnts|server)' | head -n1)"
				[ -n "$asset" ] && {
					echo "$asset"
					return 0
				}
			done

			asset="$(printf '%s\n' "$urls" | grep -iE '/vnts(2)?[-_]' | head -n1)"
			[ -n "$asset" ] && {
				echo "$asset"
				return 0
			}
		;;
	esac

	asset="$(printf '%s\n' "$urls" | grep -iE '(\.tar\.gz|\.tgz|\.tar\.xz|\.zip)$' | head -n1)"
	[ -n "$asset" ] && {
		echo "$asset"
		return 0
	}

	asset="$(printf '%s\n' "$urls" | head -n1)"
	[ -n "$asset" ] && {
		echo "$asset"
		return 0
	}

	return 1
}

extract_release_asset() {
	local asset_file="$1"
	local dest_dir="$2"
	local base

	rm -rf "$dest_dir"
	mkdir -p "$dest_dir"

	case "$asset_file" in
		*.tar.gz|*.tgz)
			tar -xzf "$asset_file" -C "$dest_dir" >/dev/null 2>&1 || return 1
		;;
		*.tar.xz)
			tar -xJf "$asset_file" -C "$dest_dir" >/dev/null 2>&1 || return 1
		;;
		*.zip)
			if command -v unzip >/dev/null 2>&1; then
				unzip -qo "$asset_file" -d "$dest_dir" >/dev/null 2>&1 || return 1
			else
				return 1
			fi
		;;
		*)
			base="$(basename "$asset_file")"
			cp -f "$asset_file" "${dest_dir}/${base}" >/dev/null 2>&1 || return 1
		;;
	esac
}

locate_extracted_bin() {
	local root="$1"
	local name="$2"
	local alt_dash alt_under found

	alt_dash="${name//_/-}"
	alt_under="${name//-/_}"

	found="$(
		find "$root" -type f \
			\( \
				-name "$name" -o \
				-name "${name}.bin" -o \
				-name "$alt_dash" -o \
				-name "${alt_dash}.bin" -o \
				-name "$alt_under" -o \
				-name "${alt_under}.bin" -o \
				-name "${name}-*" -o \
				-name "${name}_*" -o \
				-name "${alt_dash}-*" -o \
				-name "${alt_dash}_*" -o \
				-name "${alt_under}-*" -o \
				-name "${alt_under}_*" \
			\) 2>/dev/null | head -n1
	)"
	[ -n "$found" ] && {
		echo "$found"
		return 0
	}

	case "$name" in
		vnt2_cli)
			find "$root" -type f \( -name "vnt-cli" -o -name "vnt_cli" -o -name "vnt-cli-*" -o -name "vnt_cli_*" \) 2>/dev/null | head -n1
			return 0
		;;
		vnt2_ctrl)
			find "$root" -type f \( -name "vnt-ctrl" -o -name "vnt_ctrl" -o -name "vnt-ctrl-*" -o -name "vnt_ctrl_*" \) 2>/dev/null | head -n1
			return 0
		;;
		vnt2_web)
			find "$root" -type f \( -name "vnt-web" -o -name "vnt_web" -o -name "vnt-web-*" -o -name "vnt_web_*" \) 2>/dev/null | head -n1
			return 0
		;;
		vnts2)
			find "$root" -type f \( -name "vnts" -o -name "vnts-*" -o -name "vnts_*" \) 2>/dev/null | head -n1
			return 0
		;;
	esac

	return 1
}

cache_bundle_ready() {
	local extracted_dir="$1"
	local scope="$2"

	case "$scope" in
		cli)
			ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnt2_cli")" && ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnt2_ctrl")"
		;;
		web)
			ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnt2_web")"
		;;
		server)
			ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnts2")" || ensure_exec "$(locate_extracted_bin "$extracted_dir" "vnts")"
		;;
		*)
			return 1
		;;
	esac
}

auto_download_bundle() {
	local cfg="$1"
	local scope="$2"
	local state_file="$3"

	local auto_download download_tag download_repo api_url arch_name arch_patterns
	local cache_key cache_dir json_file release_tag asset_url asset_name asset_file extracted_dir
	local cli_bin ctrl_bin web_bin server_bin server_name

	config_get_bool auto_download "$cfg" "auto_download" "1"
	[ "$auto_download" = "1" ] || {
		write_download_state "$state_file" "disabled" "已关闭自动下载" "" "" "" ""
		return 1
	}

	case "$scope" in
		server)
			config_get download_tag "$cfg" "download_tag" "latest"
			config_get download_repo "$cfg" "download_repo" "lz-ycx/vnts"
		;;
		*)
			config_get download_tag "$cfg" "download_tag" "latest"
			config_get download_repo "$cfg" "download_repo" "vnt-dev/vnt"
		;;
	esac
	[ -n "$download_tag" ] || download_tag="latest"
	[ -n "$download_repo" ] || download_repo="vnt-dev/vnt"

	arch_name="$(detect_arch_name)"
	arch_patterns="$(detect_arch_patterns "$arch_name")"
	cache_key="$(sanitize_name "${download_repo}_${download_tag}_${arch_name}_${scope}")"
	cache_dir="${DOWNLOAD_CACHE_BASE}/${cache_key}"
	json_file="${cache_dir}/release.json"
	extracted_dir="${cache_dir}/extracted"

	mkdir -p "$cache_dir"

	if cache_bundle_ready "$extracted_dir" "$scope"; then
		log_download "检测到 ${scope} 已有缓存包，直接复用 ${extracted_dir}"
		write_download_state "$state_file" "cached" "已复用本地缓存程序" "$(basename "$cache_dir")" "$download_tag" "$arch_name" "$extracted_dir"

		case "$scope" in
			cli)
				cli_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_cli")"
				ctrl_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_ctrl")"
				ensure_exec "$cli_bin" && uci -q set ${CONF}.${cfg}.vnt2_cli_bin="$cli_bin"
				ensure_exec "$ctrl_bin" && uci -q set ${CONF}.${cfg}.vnt2_ctrl_bin="$ctrl_bin"
			;;
			web)
				web_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_web")"
				ensure_exec "$web_bin" && uci -q set ${CONF}.${cfg}.vnt2_web_bin="$web_bin"
			;;
			server)
				server_bin="$(locate_extracted_bin "$extracted_dir" "vnts2")"
				ensure_exec "$server_bin" || server_bin="$(locate_extracted_bin "$extracted_dir" "vnts")"
				ensure_exec "$server_bin" && uci -q set ${CONF}.${cfg}.vnts2_bin="$server_bin"
			;;
		esac
		uci commit ${CONF} >/dev/null 2>&1
		return 0
	fi

	api_url="$(get_release_api_url "$download_repo" "$download_tag")"
	write_download_state "$state_file" "querying" "正在查询 GitHub Releases" "" "$download_tag" "$arch_name" ""
	log_download "开始查询 ${scope} 对应发行版：repo=${download_repo} tag=${download_tag} arch=${arch_name}"

	if ! download_file "$api_url" "$json_file"; then
		log_download "查询 GitHub Releases 失败：${api_url}"
		write_download_state "$state_file" "failed" "查询 GitHub Releases 失败" "" "$download_tag" "$arch_name" ""
		return 1
	fi

	release_tag="$(sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$json_file" | head -n1)"
	[ -n "$release_tag" ] || release_tag="$download_tag"
	asset_url="$(select_release_asset "$json_file" "$arch_patterns" "$scope")" || {
		log_download "未找到匹配 ${arch_name} 的 ${scope} 发行资源"
		write_download_state "$state_file" "failed" "未找到匹配当前架构的发行资源" "" "$release_tag" "$arch_name" ""
		return 1
	}

	asset_name="$(basename "$asset_url")"
	asset_file="${cache_dir}/${asset_name}"
	write_download_state "$state_file" "downloading" "正在下载发行资源" "$asset_name" "$release_tag" "$arch_name" ""
	log_download "选中资源 ${asset_name}"

	if [ ! -s "$asset_file" ]; then
		if ! download_file "$asset_url" "$asset_file"; then
			log_download "下载发行资源失败：${asset_url}"
			write_download_state "$state_file" "failed" "下载发行资源失败" "$asset_name" "$release_tag" "$arch_name" ""
			return 1
		fi
	else
		log_download "复用已下载资源 ${asset_file}"
	fi

	write_download_state "$state_file" "extracting" "正在解压或整理程序文件" "$asset_name" "$release_tag" "$arch_name" ""
	if ! extract_release_asset "$asset_file" "$extracted_dir"; then
		log_download "解压失败：${asset_file}"
		write_download_state "$state_file" "failed" "解压发行资源失败" "$asset_name" "$release_tag" "$arch_name" ""
		return 1
	fi

	case "$scope" in
		cli)
			cli_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_cli")"
			ctrl_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_ctrl")"
			if ! ensure_exec "$cli_bin" || ! ensure_exec "$ctrl_bin"; then
				log_download "下载包中未找到完整的 vnt2_cli / vnt2_ctrl"
				write_download_state "$state_file" "failed" "下载包中未找到完整的 vnt2_cli / vnt2_ctrl" "$asset_name" "$release_tag" "$arch_name" ""
				return 1
			fi
			uci -q set ${CONF}.${cfg}.vnt2_cli_bin="$cli_bin"
			uci -q set ${CONF}.${cfg}.vnt2_ctrl_bin="$ctrl_bin"
			uci commit ${CONF} >/dev/null 2>&1
			log_download "CLI 程序已准备完成：cli=${cli_bin} ctrl=${ctrl_bin}"
			write_download_state "$state_file" "success" "已自动下载并准备 vnt2_cli / vnt2_ctrl" "$asset_name" "$release_tag" "$arch_name" "$cli_bin"
			return 0
		;;
		web)
			web_bin="$(locate_extracted_bin "$extracted_dir" "vnt2_web")"
			if ! ensure_exec "$web_bin"; then
				log_download "下载包中未找到 vnt2_web"
				write_download_state "$state_file" "failed" "下载包中未找到 vnt2_web" "$asset_name" "$release_tag" "$arch_name" ""
				return 1
			fi
			uci -q set ${CONF}.${cfg}.vnt2_web_bin="$web_bin"
			uci commit ${CONF} >/dev/null 2>&1
			log_download "Web 程序已准备完成：web=${web_bin}"
			write_download_state "$state_file" "success" "已自动下载并准备 vnt2_web" "$asset_name" "$release_tag" "$arch_name" "$web_bin"
			return 0
		;;
		server)
			server_name="vnts2"
			server_bin="$(locate_extracted_bin "$extracted_dir" "$server_name")"
			if ! ensure_exec "$server_bin"; then
				server_name="vnts"
				server_bin="$(locate_extracted_bin "$extracted_dir" "$server_name")"
			fi
			if ! ensure_exec "$server_bin"; then
				log_download "下载包中未找到 vnts2 / vnts"
				write_download_state "$state_file" "failed" "下载包中未找到 vnts2 / vnts" "$asset_name" "$release_tag" "$arch_name" ""
				return 1
			fi
			uci -q set ${CONF}.${cfg}.vnts2_bin="$server_bin"
			uci commit ${CONF} >/dev/null 2>&1
			log_download "服务端程序已准备完成：server=${server_bin}"
			write_download_state "$state_file" "success" "已自动下载并准备 vnts2" "$asset_name" "$release_tag" "$arch_name" "$server_bin"
			return 0
		;;
	esac

	write_download_state "$state_file" "failed" "未知下载范围" "$asset_name" "$release_tag" "$arch_name" ""
	return 1
}

prepare_binary() {
	local cfg="$1"
	local option="$2"
	local default_path="$3"
	local upload_name="$4"
	local state_file="$5"
	local scope="$6"

	local bin
	config_get bin "$cfg" "$option" "$default_path"

	if ensure_exec "$bin"; then
		echo "$bin"
		return 0
	fi

	if auto_download_bundle "$cfg" "$scope" "$state_file"; then
		bin="$(uci -q get ${CONF}.${cfg}.${option})"
		if ensure_exec "$bin"; then
			echo "$bin"
			return 0
		fi
	fi

	local uploaded
	uploaded="$(find_uploaded_bin "$upload_name")"
	if [ -n "$uploaded" ]; then
		log_download "${scope} 自动下载失败，回退到本地上传程序 ${uploaded}"
		bin="$uploaded"
		uci -q set ${CONF}.${cfg}.${option}="$bin"
		uci commit ${CONF} >/dev/null 2>&1
		write_download_state "$state_file" "fallback" "自动下载失败，已回退到本地上传程序" "$(basename "$uploaded")" "" "$(detect_arch_name)" "$uploaded"
	fi

	ensure_exec "$bin" || return 1
	echo "$bin"
	return 0
}

toml_get_raw() {
	local file="$1"
	local key="$2"
	[ -f "$file" ] || return 1
	sed -n "s/^[[:space:]]*${key}[[:space:]]*=[[:space:]]*//p" "$file" | head -n1
}

toml_get_string() {
	local file="$1"
	local key="$2"
	local raw val

	raw="$(toml_get_raw "$file" "$key" 2>/dev/null)"
	raw="$(trim_value "$raw")"
	case "$raw" in
		\"*\")
			val="${raw#\"}"
			val="${val%\"}"
			printf '%s\n' "$val" | sed 's/\\"/"/g; s/\\\\/\\/g'
		;;
		*)
			printf '%s\n' "$raw"
		;;
	esac
}

toml_get_bool() {
	local file="$1"
	local key="$2"
	local raw
	raw="$(trim_value "$(toml_get_raw "$file" "$key" 2>/dev/null)")"
	[ "$raw" = "true" ] && echo "1" || echo "0"
}

toml_validate_client_config() {
	local file="$1"
	local network_code server_line

	[ -f "$file" ] || {
		log_cli "客户端配置文件不存在：$file"
		return 1
	}

	network_code="$(trim_value "$(toml_get_string "$file" "network_code")")"
	server_line="$(trim_value "$(toml_get_raw "$file" "server")")"

	[ -n "$network_code" ] || {
		log_cli "客户端配置校验失败：network_code 不能为空"
		return 1
	}

	case "$server_line" in
		\[*\])
			:
		;;
		*)
			log_cli "客户端配置校验失败：server 列表不能为空"
			return 1
		;;
	esac

	return 0
}

toml_validate_server_config() {
	local file="$1"
	[ -f "$file" ] || {
		log_server "服务端配置文件不存在：$file"
		return 1
	}
	return 0
}

configure_network() {
	local tun_name="$1"
	local forward_list="$2"

	[ -n "$tun_name" ] || tun_name="vnt-tun"

	uci -q delete network.VNT2
	uci set network.VNT2='interface'
	uci set network.VNT2.proto='none'
	uci set network.VNT2.device="$tun_name"
	uci set network.VNT2.ifname="$tun_name"

	uci -q delete firewall.vnt2zone
	uci set firewall.vnt2zone='zone'
	uci set firewall.vnt2zone.name='VNT2'
	uci set firewall.vnt2zone.input='ACCEPT'
	uci set firewall.vnt2zone.output='ACCEPT'
	uci set firewall.vnt2zone.forward='ACCEPT'
	uci set firewall.vnt2zone.masq='1'
	uci set firewall.vnt2zone.mtu_fix='1'
	uci set firewall.vnt2zone.network='VNT2'

	case " $forward_list " in
		*" vnt2fwlan "*)
			uci set firewall.vnt2fwlan='forwarding'
			uci set firewall.vnt2fwlan.src='VNT2'
			uci set firewall.vnt2fwlan.dest='lan'
		;;
		*)
			uci -q delete firewall.vnt2fwlan
		;;
	esac

	case " $forward_list " in
		*" vnt2fwwan "*)
			uci set firewall.vnt2fwwan='forwarding'
			uci set firewall.vnt2fwwan.src='VNT2'
			uci set firewall.vnt2fwwan.dest='wan'
		;;
		*)
			uci -q delete firewall.vnt2fwwan
		;;
	esac

	case " $forward_list " in
		*" lanfwvnt2 "*)
			uci set firewall.lanfwvnt2='forwarding'
			uci set firewall.lanfwvnt2.src='lan'
			uci set firewall.lanfwvnt2.dest='VNT2'
		;;
		*)
			uci -q delete firewall.lanfwvnt2
		;;
	esac

	case " $forward_list " in
		*" wanfwvnt2 "*)
			uci set firewall.wanfwvnt2='forwarding'
			uci set firewall.wanfwvnt2.src='wan'
			uci set firewall.wanfwvnt2.dest='VNT2'
		;;
		*)
			uci -q delete firewall.wanfwvnt2
		;;
	esac

	[ -n "$(uci changes network)" ] && uci commit network && /etc/init.d/network reload >/dev/null 2>&1
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
	sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1
}

cleanup_network() {
	uci -q delete network.VNT2
	uci -q delete firewall.vnt2zone
	uci -q delete firewall.vnt2fwlan
	uci -q delete firewall.vnt2fwwan
	uci -q delete firewall.lanfwvnt2
	uci -q delete firewall.wanfwvnt2
	[ -n "$(uci changes network)" ] && uci commit network && /etc/init.d/network reload >/dev/null 2>&1
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

ensure_firewall_rule() {
	local rule="$1"
	local name="$2"
	local proto="$3"
	local port="$4"

	uci set firewall.${rule}='rule'
	uci set firewall.${rule}.name="${name}"
	uci set firewall.${rule}.src='wan'
	uci set firewall.${rule}.target='ACCEPT'
	uci set firewall.${rule}.proto="${proto}"
	uci set firewall.${rule}.dest_port="${port}"
}

configure_web_firewall() {
	local host="$1"
	local port="$2"
	local wan="$3"

	uci -q delete firewall.vnt2web
	if [ "$wan" = "1" ] && [ -n "$port" ] && [ "$host" = "0.0.0.0" -o "$host" = "::" ]; then
		ensure_firewall_rule "vnt2web" "vnt2_web" "tcp" "$port"
	fi
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

cleanup_web_firewall() {
	uci -q delete firewall.vnt2web
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

configure_server_firewall() {
	local tcp_bind="$1"
	local quic_bind="$2"
	local ws_bind="$3"
	local web_bind="$4"
	local open_tcp="$5"
	local open_quic="$6"
	local open_ws="$7"
	local open_web="$8"

	local tcp_port quic_port ws_port web_port
	tcp_port="${tcp_bind##*:}"
	quic_port="${quic_bind##*:}"
	ws_port="${ws_bind##*:}"
	web_port="${web_bind##*:}"

	uci -q delete firewall.vnts2_tcp
	uci -q delete firewall.vnts2_quic
	uci -q delete firewall.vnts2_ws
	uci -q delete firewall.vnts2_web

	[ "$open_tcp" = "1" ] && [ -n "$tcp_port" ] && ensure_firewall_rule "vnts2_tcp" "vnts2_tcp" "tcp" "$tcp_port"
	[ "$open_quic" = "1" ] && [ -n "$quic_port" ] && ensure_firewall_rule "vnts2_quic" "vnts2_quic" "udp" "$quic_port"
	[ "$open_ws" = "1" ] && [ -n "$ws_port" ] && ensure_firewall_rule "vnts2_ws" "vnts2_ws" "tcp" "$ws_port"
	[ "$open_web" = "1" ] && [ -n "$web_port" ] && ensure_firewall_rule "vnts2_web" "vnts2_web" "tcp" "$web_port"

	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

cleanup_server_firewall() {
	uci -q delete firewall.vnts2_tcp
	uci -q delete firewall.vnts2_quic
	uci -q delete firewall.vnts2_ws
	uci -q delete firewall.vnts2_web
	[ -n "$(uci changes firewall)" ] && uci commit firewall && /etc/init.d/firewall reload >/dev/null 2>&1
}

prepare_cli_runtime() {
	local cfg="$1"
	local forward_list bind_dev tun_name no_tun

	CLI_CONF_FILE="${CLI_CONF_DEFAULT}"

	if ! toml_validate_client_config "${CLI_CONF_FILE}"; then
		return 1
	fi

	config_get bind_dev "$cfg" "bind_dev"
	config_list_foreach "$cfg" vnt2_forward append_forward_item
	forward_list="${VNT2_FORWARD_LIST}"

	tun_name="$(trim_value "$(toml_get_string "${CLI_CONF_FILE}" "tun_name")")"
	[ -n "$tun_name" ] || tun_name="vnt-tun"
	no_tun="$(toml_get_bool "${CLI_CONF_FILE}" "no_tun")"

	VNT2_BIND_DEV="${bind_dev}"
	VNT2_TUN_NAME="${tun_name}"
	VNT2_NO_TUN="${no_tun}"
	VNT2_FORWARD_LIST="${forward_list}"
	return 0
}

append_forward_item() {
	local value="$1"
	value="$(trim_value "$value")"
	[ -n "$value" ] || return 0
	if [ -n "${VNT2_FORWARD_LIST}" ]; then
		VNT2_FORWARD_LIST="${VNT2_FORWARD_LIST} ${value}"
	else
		VNT2_FORWARD_LIST="${value}"
	fi
}

prepare_server_runtime() {
	SERVER_CONF_FILE="${SERVER_CONF_DEFAULT}"

	if ! toml_validate_server_config "${SERVER_CONF_FILE}"; then
		return 1
	fi

	VNTS2_TCP_BIND="$(trim_value "$(toml_get_string "${SERVER_CONF_FILE}" "tcp")")"
	VNTS2_QUIC_BIND="$(trim_value "$(toml_get_string "${SERVER_CONF_FILE}" "quic")")"
	VNTS2_WS_BIND="$(trim_value "$(toml_get_string "${SERVER_CONF_FILE}" "ws")")"
	VNTS2_WEB_BIND="$(trim_value "$(toml_get_string "${SERVER_CONF_FILE}" "web")")"

	[ -n "${VNTS2_TCP_BIND}" ] || VNTS2_TCP_BIND="0.0.0.0:29872"
	[ -n "${VNTS2_QUIC_BIND}" ] || VNTS2_QUIC_BIND="0.0.0.0:29872"
	[ -n "${VNTS2_WS_BIND}" ] || VNTS2_WS_BIND="0.0.0.0:29872"
	[ -n "${VNTS2_WEB_BIND}" ] || VNTS2_WEB_BIND="0.0.0.0:29871"

	return 0
}

start_cli_instance() {
	local cfg="$1"
	local enabled cli_bin ctrl_bin

	config_get_bool enabled "$cfg" "enabled" "0"
	if [ "$enabled" != "1" ]; then
		log_cli "未启用，跳过启动"
		return 0
	fi

	log_cli "开始启动"
	config_get cli_bin "$cfg" "vnt2_cli_bin" "/usr/bin/vnt2_cli"
	config_get ctrl_bin "$cfg" "vnt2_ctrl_bin" "/usr/bin/vnt2_ctrl"

	if ! ensure_exec "$cli_bin" || ! ensure_exec "$ctrl_bin"; then
		log_cli "检测到 CLI/CTRL 程序不完整，尝试自动下载或回退到上传程序"
		cli_bin="$(prepare_binary "$cfg" "vnt2_cli_bin" "/usr/bin/vnt2_cli" "vnt2_cli" "$DOWNLOAD_CLI_STATE" "cli")" || {
			log_cli "启动失败：未找到完整的 vnt2_cli / vnt2_ctrl，请上传或安装程序"
			return 1
		}
		ctrl_bin="$(uci -q get ${CONF}.${cfg}.vnt2_ctrl_bin)"
		if ! ensure_exec "$ctrl_bin"; then
			log_cli "启动失败：vnt2_ctrl 缺失，自动下载或上传回退未准备完整"
			return 1
		fi
	else
		log_cli "检测到现有 CLI/CTRL 程序完整：cli=${cli_bin} ctrl=${ctrl_bin}"
	fi

	VNT2_FORWARD_LIST=""
	if ! prepare_cli_runtime "$cfg"; then
		log_cli "启动失败：客户端 TOML 配置校验失败"
		return 1
	fi

	if [ "${VNT2_NO_TUN}" != "1" ]; then
		configure_network "${VNT2_TUN_NAME}" "${VNT2_FORWARD_LIST}"
	else
		cleanup_network
	fi

	log_cli "使用 ${cli_bin} 启动，配置文件 ${CLI_CONF_FILE}"
	procd_open_instance "vnt2_cli"
	[ -n "${VNT2_BIND_DEV}" ] && procd_set_param env VNT_BIND_DEV="${VNT2_BIND_DEV}"
	procd_set_param command /bin/sh -c "exec \"${cli_bin}\" --conf \"${CLI_CONF_FILE}\" >>\"${CLI_LOG}\" 2>&1"
	procd_set_param stdout 0
	procd_set_param stderr 0
	procd_set_param respawn
	procd_set_param file "${CLI_CONF_FILE}"
	procd_set_param limits core="unlimited"
	procd_set_param limits nofile="1048576 1048576"
	procd_set_param term_timeout 10
	procd_close_instance
	date +%s >"${CLI_TIME}"
	log_cli "启动命令已提交"
}

start_web_instance() {
	local cfg="$1"
	local enabled web_bin web_host web_port web_wan log_level

	config_get_bool enabled "$cfg" "enabled" "0"
	if [ "$enabled" != "1" ]; then
		log_web "未启用，跳过启动"
		return 0
	fi

	log_web "开始启动"
	web_bin="$(prepare_binary "$cfg" "vnt2_web_bin" "/usr/bin/vnt2_web" "vnt2_web" "$DOWNLOAD_WEB_STATE" "web")" || {
		log_web "启动失败：未找到可执行文件，请上传或安装 vnt2_web"
		return 1
	}

	config_get web_host "$cfg" "web_host" "127.0.0.1"
	config_get web_port "$cfg" "web_port" "19099"
	config_get_bool web_wan "$cfg" "web_wan" "0"
	config_get log_level "$cfg" "log_level" "info"

	configure_web_firewall "$web_host" "$web_port" "$web_wan"

	log_web "使用 ${web_bin} 监听 ${web_host}:${web_port}"
	procd_open_instance "vnt2_web"
	procd_set_param env RUST_LOG="$log_level"
	procd_set_param command /bin/sh -c "exec \"${web_bin}\" --addr \"${web_host}:${web_port}\" >>\"${WEB_LOG}\" 2>&1"
	procd_set_param stdout 0
	procd_set_param stderr 0
	procd_set_param respawn
	procd_set_param limits core="unlimited"
	procd_set_param limits nofile="1048576 1048576"
	procd_set_param term_timeout 10
	procd_close_instance
	date +%s >"${WEB_TIME}"
	log_web "启动命令已提交"
}

start_server_instance() {
	local cfg="$1"
	local enabled server_bin
	local open_tcp open_quic open_ws open_web

	config_get_bool enabled "$cfg" "enabled" "0"
	if [ "$enabled" != "1" ]; then
		log_server "未启用，跳过启动"
		return 0
	fi

	log_server "开始启动"
	server_bin="$(prepare_binary "$cfg" "vnts2_bin" "/usr/bin/vnts2" "vnts2" "$DOWNLOAD_SERVER_STATE" "server")" || {
		log_server "启动失败：未找到可执行文件，请上传或安装 vnts2"
		return 1
	}

	if ! prepare_server_runtime; then
		log_server "启动失败：服务端 TOML 配置校验失败"
		return 1
	fi

	config_get_bool open_tcp "$cfg" "open_wan_tcp" "0"
	config_get_bool open_quic "$cfg" "open_wan_quic" "0"
	config_get_bool open_ws "$cfg" "open_wan_ws" "0"
	config_get_bool open_web "$cfg" "open_wan_web" "0"

	configure_server_firewall "${VNTS2_TCP_BIND}" "${VNTS2_QUIC_BIND}" "${VNTS2_WS_BIND}" "${VNTS2_WEB_BIND}" "$open_tcp" "$open_quic" "$open_ws" "$open_web"

	log_server "使用 ${server_bin} 启动，配置文件 ${SERVER_CONF_FILE}"
	procd_open_instance "vnts2"
	procd_set_param command /bin/sh -c "exec \"${server_bin}\" --conf \"${SERVER_CONF_FILE}\" >>\"${SERVER_LOG}\" 2>&1"
	procd_set_param stdout 0
	procd_set_param stderr 0
	procd_set_param respawn
	procd_set_param file "${SERVER_CONF_FILE}"
	procd_set_param limits core="unlimited"
	procd_set_param limits nofile="1048576 1048576"
	procd_set_param term_timeout 10
	procd_close_instance
	date +%s >"${SERVER_TIME}"
	log_server "启动命令已提交"
}

start_service() {
	ensure_log_files
	log_cli "服务启动流程开始"
	log_web "服务启动流程开始"
	log_server "服务启动流程开始"
	log_download "服务启动流程开始"

	config_load "${CONF}"
	start_cli_instance "vnt2_cli"
	start_web_instance "vnt2_web"
	start_server_instance "vnts2"

	log_download "服务启动流程结束"
}

stop_service() {
	ensure_log_files
	log_cli "服务停止流程开始"
	log_web "服务停止流程开始"
	log_server "服务停止流程开始"
	log_download "服务停止流程开始"

	rm -f "${CLI_TIME}" "${WEB_TIME}" "${SERVER_TIME}"
	cleanup_network
	cleanup_web_firewall
	cleanup_server_firewall

	log_cli "服务已停止"
	log_web "服务已停止"
	log_server "服务已停止"
	log_download "服务停止流程结束"
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger "${CONF}"
}
