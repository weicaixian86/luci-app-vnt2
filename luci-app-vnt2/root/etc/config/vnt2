config vnt2_cli
	option enabled '0'
	option auto_download '1'
	option download_tag 'latest'
	option download_repo 'vnt-dev/vnt'
	option vnt2_cli_bin '/usr/bin/vnt2_cli'
	option vnt2_ctrl_bin '/usr/bin/vnt2_ctrl'
	option cli_conf_file '/etc/vnt2/vnt2-cli.toml'
	list server 'quic://101.35.230.139:6660'
	option network_code '123456'
	option ip ''
	option device_id ''
	option device_name ''
	option password ''
	option mtu '1400'
	option tun_name 'vnt-tun'
	option bind_dev ''
	option no_punch '0'
	option rtx '0'
	option compress '0'
	option fec '0'
	option no_nat '0'
	option no_tun '0'
	option allow_mapping '0'
	option cert_mode 'skip'
	option ctrl_port '11233'
	option tunnel_port '0'
	list input
	list output
	list port_mapping
	list udp_stun
	list tcp_stun
	list vnt2_forward 'vnt2fwlan'
	list vnt2_forward 'vnt2fwwan'
	list vnt2_forward 'lanfwvnt2'

config vnt2_web
	option enabled '0'
	option auto_download '1'
	option download_tag 'latest'
	option download_repo 'vnt-dev/vnt'
	option vnt2_web_bin '/usr/bin/vnt2_web'
	option web_host '127.0.0.1'
	option web_port '19099'
	option web_wan '0'
	option web_user 'admin'
	option web_pass ''
	option log_level 'info'
