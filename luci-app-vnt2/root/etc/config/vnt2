config vnt2_cli
	option enabled '0'
	option auto_download '1'
	option download_tag 'latest'
	option download_repo 'vnt-dev/vnt'
	option vnt2_cli_bin '/usr/bin/vnt2_cli'
	option vnt2_ctrl_bin '/usr/bin/vnt2_ctrl'
	option network_code '123456'
	option ip ''
	option device_id ''
	option device_name ''
	option password ''
	option mtu '1400'
	option tun_name 'vnt-tun'
	option bind_dev ''
	option no_punch '0'
	option rtx '0'
	option compress '0'
	option fec '0'
	option no_nat '0'
	option no_tun '0'
	option allow_mapping '0'
	option cert_mode 'skip'
	option ctrl_port '11233'
	option tunnel_port '0'
	list input
	list output
	list port_mapping
	list udp_stun
	list tcp_stun
	list vnt2_forward 'vnt2fwlan'
	list vnt2_forward 'vnt2fwwan'
	list vnt2_forward 'lanfwvnt2'

config vnt2_web
	option enabled '0'
	option auto_download '1'
	option download_tag 'latest'
	option download_repo 'vnt-dev/vnt'
	option vnt2_web_bin '/usr/bin/vnt2_web'
	option web_host '127.0.0.1'
	option web_port '19099'
	option web_wan '0'
	option web_user 'admin'
	option web_pass ''
	option log_level 'info'

config vnts2
	option enabled '0'
	option auto_download '1'
	option download_tag 'latest'
	option download_repo 'vnt-dev/vnts'
	option vnts2_bin '/usr/bin/vnts2'
	option tcp_bind '0.0.0.0:29872'
	option quic_bind '0.0.0.0:29872'
	option ws_bind '0.0.0.0:29872'
	option web_bind '0.0.0.0:29871'
	option server_quic_bind ''
	option cert ''
	option key ''
	option network '10.26.0.0/24'
	option lease_duration '86400'
	option persistence '1'
	option username 'admin'
	option password 'admin'
	option server_token ''
	list white_list
	list peer_servers
	list custom_net
	option open_wan_tcp '0'
	option open_wan_quic '0'
	option open_wan_ws '0'
	option open_wan_web '0'
